{
    "name": "equinox-map",
    "version": "0.1.0",
    "private": true,
    "config": {
        "databaseItemsDir": "public/test-items",
        "exportDir": "app/data/"
    },
    "scripts": {
        "dev": "next dev --turbopack",
        "build:convert": "ts-node --project tsconfig.scripts.json --transpile-only scripts/convert-markers.ts",
        "build:extract": "ts-node --project tsconfig.scripts.json --transpile-only scripts/extract-resources.ts",
        "build:prepare": "ts-node --project tsconfig.scripts.json --transpile-only scripts/prepare-icons.ts",
        "database:compress": "ts-node --project tsconfig.scripts.json --transpile-only scripts/compress-database.ts $npm_package_config_databaseItemsDir $npm_package_config_exportDir",
        "database:validate": "ts-node --project tsconfig.scripts.json --transpile-only scripts/validate-database.ts $npm_package_config_databaseItemsDir",
        "build": "npm run build:convert && npm run database:validate && npm run database:compress && next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@phosphor-icons/react": "2.1.10",
        "driver.js": "1.4.0",
        "maplibre-gl": "5.19.0",
        "next": "16.1.7",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@types/node": "25.3.3",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "eslint": "9.39.3",
        "eslint-config-next": "16.1.6",
        "prettier": "3.8.1",
        "sharp": "0.34.5",
        "ts-node": "10.9.2",
        "typescript": "5.9.3"
    }
}
